# Database
# Pooled/runtime connection string
DATABASE_URL="postgresql://user:password@pooler-host:5432/dbname?schema=public"

# Direct database connection for Prisma migrations
DIRECT_URL="postgresql://user:password@db.project-ref.supabase.co:5432/dbname?schema=public"

# Auth.js v5
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="https://your-app.vercel.app"

# Google OAuth
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
